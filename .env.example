# ── Supabase (hosted project) ────────────────────────────────────────────────
# Build-time: inlined into the client bundle. Changing them requires a rebuild.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Bot runner ───────────────────────────────────────────────────────────────
# Direct Postgres connection (bypasses RLS). Use the Supabase "Session pooler"
# connection string (Dashboard → Connect); the VPS is IPv4-only by default.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── AI features (deck-doctor, card-behavior generator) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Hosting ──────────────────────────────────────────────────────────────────
# Public hostname Caddy serves (must point at the VPS in DNS).
APP_DOMAIN=app.dweemo.nl

# ── Optional toggles ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SHOW_DEV_CONTROLS=false
# NEXT_PUBLIC_ENABLE_FALLBACK_REFRESH=true
# NEXT_PUBLIC_FALLBACK_REFRESH_MS=2000
