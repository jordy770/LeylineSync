# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# supabase local state
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

/components/default-cards-20260429211148.json
# claude code local settings
.claude/settings.local.json

# Supabase scratch schema dump (local baseline authoring only)
supabase/_hosted_schema.sql

# Scryfall oracle dump (165 MB) — used only by scripts/import-scryfall-cards.mjs.
# Download a fresh "Oracle Cards" bulk file from https://scryfall.com/docs/api/bulk-data
# into lib/ (the importer's default path) or pass --file.
lib/oracle-cards*.json

# Generated API-doc viewer assets (jsdoc/docdash output).
/doc/

# OpenWolf transient runtime state (regenerated every session).
.wolf/hooks/_session.json
.wolf/token-ledger.json
.wolf/designqc-captures/
.wolf/designqc-report.json

# Generated deck triage reports (regenerate with npm run deck:triage).
docs/commander-decks/*.triage.md
